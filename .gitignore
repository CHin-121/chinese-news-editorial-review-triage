# macOS
.DS_Store
.AppleDouble
.LSOverride

# Python caches and tooling
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments and local environment files
.venv/
venv/
env/
ENV/
.env
.env.*
.python-version

# IDE and editor files
.idea/
.vscode/
*.iml
*.swp
*.swo

# Logs and temporary files
*.log
*.tmp
*.temp
~$*
.~lock.*

# Raw and local datasets
data/*
!data/README.md
!data/raw/
data/raw/*
**/cnews.train.txt
**/cnews.test.txt
**/cnews*.txt

# Models and checkpoints
*.ckpt
*.pt
*.pth
*.bin
*.pkl
*.pickle
*.joblib
*.model

# Large or unverified font files
fonts/
*.otf
*.ttf
*.ttc

# Reports: permit only the policy note and a future verified redacted PDF
report/*
!report/README.md
!report/course-report-redacted.pdf
*unredacted*
*original-report*
